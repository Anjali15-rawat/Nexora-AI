# Commerce Copilot AI — Environment Variables
# Copy this file to .env and fill in your values.
#
# Variables prefixed with VITE_ are exposed to the browser.
# All others are server-only and never sent to the client.

# ─── Supabase (Required) ──────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase (same URL, different keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Gemini AI (Required for AI engines) ───────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── App Configuration ────────────────────────────────────────
# Base URL used for OAuth redirects and email links
VITE_APP_URL=http://localhost:3000

# ─── OAuth (Configure in Supabase Dashboard) ─────────────────
# Google: https://supabase.com/docs/guides/auth/social-login/auth-google
# GitHub: https://supabase.com/docs/guides/auth/social-login/auth-github
# Set the callback URL in each provider to:
#   {VITE_SUPABASE_URL}/auth/v1/callback

# ─── Environment ──────────────────────────────────────────────
# NODE_ENV is set automatically by the framework
# NODE_ENV=development

# ─── ElevenLabs Voice Integration ─────────────────────────────
# Get API Key from ElevenLabs Dashboard profile settings.
# Voice ID can be retrieved from My Voices or Voice Library.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
